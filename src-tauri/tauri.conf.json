{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BRAWLGEBRA",
  "version": "1.0.0",
  "identifier": "com.kmuralistudio.brawlgebra",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run prep",
    "beforeBuildCommand": "npm run prep"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BRAWLGEBRA",
        "width": 1280,
        "height": 720,
        "minWidth": 960,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "backgroundColor": "#000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "KMurali Studio",
    "category": "Game",
    "shortDescription": "A math-powered fighting game.",
    "longDescription": "BRAWLGEBRA is a 2D fighter where mental math is the entire economy: every correct answer fuels the aura you spend on punches, kicks, and specials. Includes The Tower, Versus, local 2P, Gauntlet, a 5-way Rumble, and the Brotherhood of the Four Functions story mode.",
    "copyright": "© 2026 KMurali Studio",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
